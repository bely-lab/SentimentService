# zip and deployment artifacts
app.zip
*.zip

# node/npm / python packaging
node_modules/
dist/
build/

# miscellaneous
*.log
| Out-File -FilePath .\.funcignore -Encoding utf8

Write-Host ".funcignore created. Contents:"
Get-Content .\.funcignore
