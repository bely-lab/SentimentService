# ignore virtual env and local secrets
.venv/
env/
venv/
local.settings.json
__pycache__/
*.pyc

# editor and IDE files
.vscode/
*.suo
*.user
*.userosscache
*.sln

# OS files
Thumbs.db
.DS_Store

# Azurite local DB files (do not deploy)
